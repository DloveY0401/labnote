{
  "name": "labnote",
  "version": "1.0.0",
  "description": "化学实验记录软件 — 基于 Electron + React + TypeScript",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npx tsc -p tsconfig.node.json && npx concurrently -k \"npx vite\" \"npx wait-on http://localhost:5173 && npx electron .\"",
    "build:electron": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "drizzle-orm": "^0.29.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "smiles-drawer": "^2.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.20.14",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  }
}
